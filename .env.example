# Two destinations, two filenames — both git-ignored, never commit real secrets.
#
#   .env.local  — host development (`npm run dev`). Copy this file there.
#   .env        — Docker Compose. Compose reads `.env` from the REPO ROOT and
#                 nothing else; it does not read .env.local. See docs/deploying.md.
#
# Under Compose, DATABASE_URL is set by the compose file, so a deployment `.env`
# usually needs only SESSION_SECRET, CRM_PASSWORD, and (on Postgres) POSTGRES_PASSWORD.

# SQLite database file path (swap to a Postgres URL when going online, then
# re-run `npm run db:generate` — see README "Deploying" / "Scale & production data").
# Under Docker the provider is baked into the image at build time: switching means
# rebuilding, not editing this URL. See docs/deploying.md.
DATABASE_URL="file:./data/clarity.db"

# Optional, Postgres only: max connections in the app's pool (default 10).
# Lower on serverless/many-replica deployments. See README "Scale & production data".
# DATABASE_POOL_MAX=10

# Shared login password (change before deploying anywhere online)
CRM_PASSWORD="clarity-dev"

# HMAC key for the session cookie (use a long random value in production)
SESSION_SECRET="dev-only-change-before-online"

# Optional — your team's mailboxes, comma-separated. Excluded from lead matching.
# Defaults to placeholders if unset.
TEAM_EMAILS="alex@example.com,jordan@example.com"

# Optional — required only for AI lead scoring. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Docker Compose, Postgres only -------------------------------------------
# Read ONLY by docker-compose.postgres.yml, which uses them both to provision the
# postgres:16 service and to assemble the app's DATABASE_URL. Irrelevant to host
# development and to docker-compose.yml (SQLite).
# POSTGRES_PASSWORD has no default: Compose refuses to start without it.
POSTGRES_USER=clarity
POSTGRES_PASSWORD=
POSTGRES_DB=clarity
